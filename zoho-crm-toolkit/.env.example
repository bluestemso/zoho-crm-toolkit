# Preferred explicit base URL.
# Example: https://www.zohoapis.com/crm/v8
ZOHO_BASE_URL=

# If ZOHO_BASE_URL is empty, the CLI builds it from these.
ZOHO_DC=com
ZOHO_API_VERSION=v8

# Auth selection:
# - auto: prefer refresh-token auth when available, otherwise use ZOHO_ACCESS_TOKEN
# - refresh_token: always use refresh-token auth
# - access_token: always use ZOHO_ACCESS_TOKEN
ZOHO_AUTH_MODE=auto

# Optional direct access token. Useful for short-lived manual testing or forced overrides.
ZOHO_ACCESS_TOKEN=

# Preferred long-lived setup for automatic token refresh.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Optional cache file for refresh-derived access tokens.
# Default: ./.zoho-token-cache.json inside the toolkit folder
ZOHO_TOKEN_CACHE_FILE=

# Optional explicit accounts server URL for token refresh.
# Examples:
# - https://accounts.zoho.com
# - https://accounts.zoho.eu
# - https://accounts.zoho.in
ZOHO_ACCOUNTS_URL=
