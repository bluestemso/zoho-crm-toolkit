#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import time
from pathlib import Path
from urllib.error import HTTPError
from urllib.parse import urlencode
from urllib.request import Request, urlopen


ROOT = Path(__file__).resolve().parent.parent
SPEC_PATH = ROOT / "spec" / "endpoints.json"
TOKEN_URLS_BY_DC = {
    "com": "https://accounts.zoho.com",
    "eu": "https://accounts.zoho.eu",
    "in": "https://accounts.zoho.in",
    "cn": "https://accounts.zoho.com.cn",
    "au": "https://accounts.zoho.com.au",
}
AUTH_CONTEXT = None
AUTH_MODE_VALUES = {"auto", "access_token", "refresh_token"}
AUTH_RETRY_STATUS_CODES = {400, 401}
DEFAULT_CONNECTION_CHECK_SELECTORS = ("getorganization", "getavailableapis")
AUTH_RETRY_MARKERS = (
    "invalid oauth token",
    "invalid_oauth_token",
    "invalid oauth",
    "unauthorized access token",
    "authentication failure",
    "oauth token",
)
AUTH_SCOPE_FAILURE_MARKERS = (
    "required oauth scope is missing",
    "insufficient scope",
)
AUTH_PERMISSION_FAILURE_MARKERS = (
    "permission denied",
    "no permission",
)


def env_file_candidates():
    explicit = os.environ.get("ZOHO_ENV_FILE")
    if explicit:
        return [Path(explicit).expanduser()]
    return [
        Path.cwd() / ".env.zoho",
        Path.cwd() / ".env",
        ROOT / ".env.zoho",
        ROOT / ".env",
    ]


def parse_env_assignment(line):
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        return None
    if stripped.startswith("export "):
        stripped = stripped[7:].strip()
    key, sep, raw_value = stripped.partition("=")
    if not sep:
        return None
    key = key.strip()
    if not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", key):
        return None
    value = raw_value.strip()
    if value:
        try:
            parsed_parts = shlex.split(value, comments=True, posix=True)
        except ValueError:
            parsed_parts = [value]
        if len(parsed_parts) == 1:
            value = parsed_parts[0]
    return key, value


def load_env_files():
    for candidate in env_file_candidates():
        if not candidate.exists() or not candidate.is_file():
            continue
        for line in candidate.read_text(encoding="utf-8").splitlines():
            parsed = parse_env_assignment(line)
            if parsed is None:
                continue
            key, value = parsed
            os.environ.setdefault(key, value)
        return candidate
    return None


def load_spec():
    return json.loads(SPEC_PATH.read_text(encoding="utf-8"))


def endpoint_text(endpoint):
    parts = [
        endpoint.get("slug", ""),
        endpoint.get("title", ""),
        endpoint.get("description", ""),
        endpoint.get("section", ""),
        endpoint.get("group", ""),
        endpoint.get("method", ""),
        endpoint.get("path", ""),
        " ".join(endpoint.get("tags", [])),
        " ".join(endpoint.get("scopes", [])),
        " ".join(endpoint.get("supported_modules", [])),
        " ".join(parameter.get("name", "") for parameter in endpoint.get("parameter_details", [])),
    ]
    return " ".join(part for part in parts if part).lower()


def parse_pairs(values):
    parsed = {}
    for value in values:
        key, sep, raw = value.partition("=")
        if not sep:
            raise SystemExit(f"Expected KEY=VALUE, got: {value}")
        parsed[key] = raw
    return parsed


def render_path(path_template, path_params):
    rendered = path_template
    for key, value in path_params.items():
        rendered = rendered.replace("{" + key + "}", value)
    missing = re.findall(r"{([^}]+)}", rendered)
    if missing:
        raise SystemExit("Missing path parameter(s): " + ", ".join(missing))
    return rendered


def find_endpoint(spec, selector):
    selector = selector.strip().lower()
    matches = [
        endpoint
        for endpoint in spec
        if endpoint["slug"] == selector or endpoint["title"].lower() == selector
    ]
    if not matches:
        raise SystemExit(f"Unknown endpoint: {selector}")
    return matches[0]


def build_base_url():
    explicit = os.environ.get("ZOHO_BASE_URL")
    if explicit:
        return explicit.rstrip("/")
    dc = os.environ.get("ZOHO_DC", "com")
    version = os.environ.get("ZOHO_API_VERSION", "v8")
    return f"https://www.zohoapis.{dc}/crm/{version}".rstrip("/")


def build_accounts_url():
    explicit = os.environ.get("ZOHO_ACCOUNTS_URL")
    if explicit:
        return explicit.rstrip("/")
    dc = os.environ.get("ZOHO_DC", "com").lower()
    if dc not in TOKEN_URLS_BY_DC:
        raise SystemExit(
            f"Unsupported ZOHO_DC={dc!r}. Set ZOHO_ACCOUNTS_URL explicitly for your region."
        )
    return TOKEN_URLS_BY_DC[dc]


def resolve_auth_mode():
    mode = os.environ.get("ZOHO_AUTH_MODE", "auto").strip().lower().replace("-", "_")
    if mode not in AUTH_MODE_VALUES:
        raise SystemExit(
            f"Unsupported ZOHO_AUTH_MODE={mode!r}. Use one of: "
            + ", ".join(sorted(AUTH_MODE_VALUES))
            + "."
        )
    return mode


def current_time():
    return int(time.time())


def parse_expiry_seconds(payload):
    for key in ("expires_in_sec", "expires_in"):
        value = payload.get(key)
        if value in (None, ""):
            continue
        try:
            seconds = int(value)
        except (TypeError, ValueError):
            continue
        if seconds > 1_000_000:
            seconds //= 1000
        if seconds > 0:
            return seconds
    return None


def token_cache_path():
    explicit = os.environ.get("ZOHO_TOKEN_CACHE_FILE")
    if explicit:
        return Path(explicit).expanduser()
    return ROOT / ".zoho-token-cache.json"


def read_token_cache():
    path = token_cache_path()
    if not path.exists():
        return None
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(payload, dict):
        return None
    return payload


def write_token_cache(auth_context):
    path = token_cache_path()
    payload = {
        "access_token": auth_context["access_token"],
        "api_domain": auth_context.get("api_domain"),
        "expires_at": auth_context.get("expires_at"),
        "refreshed_at": auth_context.get("refreshed_at"),
    }
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
    try:
        path.chmod(0o600)
    except OSError:
        pass


def clear_token_cache():
    path = token_cache_path()
    try:
        path.unlink()
    except FileNotFoundError:
        return
    except OSError:
        return


def refresh_credentials():
    client_id = os.environ.get("ZOHO_CLIENT_ID")
    client_secret = os.environ.get("ZOHO_CLIENT_SECRET")
    refresh_token = os.environ.get("ZOHO_REFRESH_TOKEN")
    if not (client_id and client_secret and refresh_token):
        return None
    return {
        "client_id": client_id,
        "client_secret": client_secret,
        "refresh_token": refresh_token,
    }


def can_refresh_access_token():
    return refresh_credentials() is not None


def auth_context_is_usable(auth_context):
    if not auth_context:
        return False
    access_token = auth_context.get("access_token")
    if not access_token:
        return False
    expires_at = auth_context.get("expires_at")
    if expires_at is None:
        return True
    try:
        return int(expires_at) > current_time() + 30
    except (TypeError, ValueError):
        return False


def load_cached_auth_context():
    cached = read_token_cache()
    if not auth_context_is_usable(cached):
        return None
    return {
        "access_token": cached["access_token"],
        "api_domain": cached.get("api_domain"),
        "expires_at": cached.get("expires_at"),
        "refreshed_at": cached.get("refreshed_at"),
        "source": "refresh_token_cache",
    }


def build_direct_access_token_context():
    direct_token = os.environ.get("ZOHO_ACCESS_TOKEN")
    if not direct_token:
        return None
    return {
        "access_token": direct_token,
        "api_domain": None,
        "expires_at": None,
        "refreshed_at": None,
        "source": "direct_access_token",
    }


def refresh_access_token():
    credentials = refresh_credentials()
    if credentials is None:
        raise SystemExit(
            "Refresh-token auth requires ZOHO_CLIENT_ID + ZOHO_CLIENT_SECRET + ZOHO_REFRESH_TOKEN."
        )

    token_url = build_accounts_url() + "/oauth/v2/token"
    body = urlencode(
        {
            "client_id": credentials["client_id"],
            "client_secret": credentials["client_secret"],
            "grant_type": "refresh_token",
            "refresh_token": credentials["refresh_token"],
        }
    ).encode("utf-8")
    request = Request(
        url=token_url,
        method="POST",
        data=body,
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    try:
        with urlopen(request) as response:  # noqa: S310 - operator controls the target URL.
            payload = json.loads(response.read().decode("utf-8", errors="replace"))
    except HTTPError as error:
        try:
            payload = error.read().decode("utf-8", errors="replace")
        finally:
            error.close()
        raise SystemExit(f"Failed to refresh Zoho access token: {payload}") from error

    access_token = payload.get("access_token")
    if not access_token:
        raise SystemExit(f"Zoho token refresh did not return an access_token: {payload}")

    expires_in = parse_expiry_seconds(payload)
    # If Zoho omits expiry metadata, keep the cache window short to avoid refresh storms.
    expires_at = current_time() + (max(60, expires_in - 60) if expires_in else 300)
    auth_context = {
        "access_token": access_token,
        "api_domain": payload.get("api_domain"),
        "expires_at": expires_at,
        "refreshed_at": current_time(),
        "source": "refresh_token",
    }
    write_token_cache(auth_context)
    return auth_context


def resolve_auth_context(force_refresh=False):
    global AUTH_CONTEXT
    mode = resolve_auth_mode()

    if force_refresh:
        AUTH_CONTEXT = None
        clear_token_cache()

    if auth_context_is_usable(AUTH_CONTEXT):
        return AUTH_CONTEXT

    if mode == "access_token":
        direct_context = build_direct_access_token_context()
        if direct_context is None:
            raise SystemExit("ZOHO_AUTH_MODE=access_token requires ZOHO_ACCESS_TOKEN.")
        AUTH_CONTEXT = direct_context
        return AUTH_CONTEXT

    if mode == "refresh_token":
        if not force_refresh:
            cached_context = load_cached_auth_context()
            if cached_context is not None:
                AUTH_CONTEXT = cached_context
                return AUTH_CONTEXT
        AUTH_CONTEXT = refresh_access_token()
        return AUTH_CONTEXT

    if can_refresh_access_token():
        if not force_refresh:
            cached_context = load_cached_auth_context()
            if cached_context is not None:
                AUTH_CONTEXT = cached_context
                return AUTH_CONTEXT
        AUTH_CONTEXT = refresh_access_token()
        return AUTH_CONTEXT

    direct_context = build_direct_access_token_context()
    if direct_context is not None:
        AUTH_CONTEXT = direct_context
        return AUTH_CONTEXT

    raise SystemExit(
        "Set ZOHO_ACCESS_TOKEN, or set ZOHO_CLIENT_ID + ZOHO_CLIENT_SECRET + "
        "ZOHO_REFRESH_TOKEN."
    )


def maybe_refresh_access_token():
    return resolve_auth_context(force_refresh=False)


def resolve_request_base_url(auth_context):
    explicit = os.environ.get("ZOHO_BASE_URL")
    if explicit:
        return explicit.rstrip("/")
    api_domain = auth_context.get("api_domain")
    if api_domain:
        version = os.environ.get("ZOHO_API_VERSION", "v8")
        return f"{api_domain.rstrip('/')}/crm/{version}".rstrip("/")
    return build_base_url()


def should_retry_with_fresh_token(status, body, auth_context):
    if not can_refresh_access_token():
        return False
    if resolve_auth_mode() == "access_token":
        return False
    if not auth_context:
        return False
    if status not in AUTH_RETRY_STATUS_CODES:
        return False

    normalized_body = body.lower()
    if any(marker in normalized_body for marker in AUTH_SCOPE_FAILURE_MARKERS):
        return False
    return any(marker in normalized_body for marker in AUTH_RETRY_MARKERS)


def send_request(url, method, request_headers, body_bytes):
    request = Request(url=url, method=method.upper(), data=body_bytes, headers=request_headers)
    try:
        with urlopen(request) as response:  # noqa: S310 - operator controls the target URL.
            body = response.read().decode("utf-8", errors="replace")
            return response.status, dict(response.headers.items()), body, url, request_headers
    except HTTPError as error:
        try:
            body = error.read().decode("utf-8", errors="replace")
        finally:
            error.close()
        return error.code, dict(error.headers.items()), body, url, request_headers


def execute_request(endpoint, path_params, query_params, headers, body_bytes):
    method = endpoint.get("method")
    path = endpoint.get("path")
    if not method or not path:
        raise SystemExit("This endpoint is missing method or path details.")

    rendered_path = render_path(path, path_params)
    auth_context = resolve_auth_context()
    url = resolve_request_base_url(auth_context) + (
        rendered_path if rendered_path.startswith("/") else "/" + rendered_path
    )
    if query_params:
        url += "?" + urlencode(query_params)

    request_headers = {"Accept": "application/json"}
    request_headers["Authorization"] = f"Zoho-oauthtoken {auth_context['access_token']}"
    request_headers.update(headers)
    if body_bytes is not None and "Content-Type" not in request_headers:
        content_type = endpoint.get("request_body", {}).get("content_type") or "application/json"
        request_headers["Content-Type"] = content_type

    status, response_headers, body, _, _ = send_request(url, method, request_headers, body_bytes)
    if should_retry_with_fresh_token(status, body, auth_context):
        fresh_auth_context = resolve_auth_context(force_refresh=True)
        request_headers["Authorization"] = f"Zoho-oauthtoken {fresh_auth_context['access_token']}"
        status, response_headers, body, _, _ = send_request(url, method, request_headers, body_bytes)
    return status, response_headers, body, url, request_headers


def maybe_parse_json(text):
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return None


def normalized_error_text(body):
    parsed = maybe_parse_json(body)
    if isinstance(parsed, dict):
        parts = []
        for key in ("code", "message", "status"):
            value = parsed.get(key)
            if isinstance(value, str):
                parts.append(value)
        details = parsed.get("details")
        if isinstance(details, dict):
            for value in details.values():
                if isinstance(value, str):
                    parts.append(value)
                elif isinstance(value, list):
                    parts.extend(str(item) for item in value)
        body = " ".join(parts) or body
    return body.lower()


def is_scope_or_permission_error(status, body):
    if status not in {400, 401, 403}:
        return False
    normalized_body = normalized_error_text(body)
    markers = AUTH_SCOPE_FAILURE_MARKERS + AUTH_PERMISSION_FAILURE_MARKERS
    return any(marker in normalized_body for marker in markers)


def filter_endpoints(spec, args, query=None):
    filtered = []
    query_text = query.lower() if query else None
    for endpoint in spec:
        if query_text and query_text not in endpoint_text(endpoint):
            continue
        if getattr(args, "method", None) and endpoint.get("method", "").lower() != args.method.lower():
            continue
        if getattr(args, "section", None) and endpoint.get("section", "").lower() != args.section.lower():
            continue
        if getattr(args, "group", None) and endpoint.get("group", "").lower() != args.group.lower():
            continue
        if getattr(args, "module", None):
            modules = [value.lower() for value in endpoint.get("supported_modules", [])]
            if args.module.lower() not in modules:
                continue
        if getattr(args, "scope", None):
            scopes = " ".join(endpoint.get("scopes", [])).lower()
            if args.scope.lower() not in scopes:
                continue
        filtered.append(endpoint)
    filtered.sort(key=lambda item: (item.get("section", ""), item.get("group", ""), item.get("title", "")))
    limit = getattr(args, "limit", None)
    if limit:
        filtered = filtered[:limit]
    return filtered


def render_result_line(endpoint):
    return (
        f"{endpoint['slug']}\t"
        f"{endpoint.get('method') or '?'}\t"
        f"{endpoint.get('section', '')}\t"
        f"{endpoint.get('group', '')}\t"
        f"{endpoint.get('title', '')}"
    )


def command_catalog(args):
    spec = load_spec()
    if args.catalog_command == "list":
        results = filter_endpoints(spec, args)
        if args.json:
            print(json.dumps(results, indent=2))
            return
        for endpoint in results:
            print(render_result_line(endpoint))
        return

    endpoint = find_endpoint(spec, args.selector)
    print(json.dumps(endpoint, indent=2))


def command_search(args):
    spec = load_spec()
    results = filter_endpoints(spec, args, query=args.query)
    if args.json:
        print(json.dumps(results, indent=2))
        return
    for endpoint in results:
        print(render_result_line(endpoint))


def build_example_from_schema(schema, include_optional=True):
    if not schema:
        return {}
    if "example" in schema:
        return schema["example"]
    if "default" in schema:
        return schema["default"]
    if "enum" in schema and schema["enum"]:
        return schema["enum"][0]
    schema_type = schema.get("type", "object")
    if schema_type == "object":
        properties = schema.get("properties", {})
        required = set(schema.get("required", []))
        if isinstance(properties, list):
            return {name: "<value>" for name in properties}
        output = {}
        for name, value in properties.items():
            if include_optional or name in required:
                output[name] = build_example_from_schema(value, include_optional=include_optional)
        return output
    if schema_type == "array":
        return [build_example_from_schema(schema.get("items", {}), include_optional=include_optional)]
    if schema_type == "integer":
        return 0
    if schema_type == "number":
        return 0
    if schema_type == "boolean":
        return False
    return "<value>"


def build_request_template(endpoint, include_optional=True):
    template = {
        "selector": endpoint["slug"],
        "method": endpoint.get("method"),
        "path": endpoint.get("path"),
        "path_params": {},
        "query": {},
        "headers": {},
    }
    for parameter in endpoint.get("parameter_details", []):
        placeholder = parameter.get("default")
        if placeholder is None:
            param_type = parameter.get("type")
            if param_type == "integer":
                placeholder = 0
            elif param_type == "number":
                placeholder = 0
            elif param_type == "boolean":
                placeholder = False
            else:
                placeholder = "<value>"
        if not include_optional and not parameter.get("required"):
            continue
        if parameter.get("in") == "path":
            template["path_params"][parameter["name"]] = placeholder
        elif parameter.get("in") == "query":
            template["query"][parameter["name"]] = placeholder
        elif parameter.get("in") == "header":
            template["headers"][parameter["name"]] = placeholder

    request_body = endpoint.get("request_body") or {}
    schema = request_body.get("schema") or {}
    if schema:
        template["body"] = build_example_from_schema(schema, include_optional=include_optional)
    return template


def command_template(args):
    spec = load_spec()
    endpoint = find_endpoint(spec, args.selector)
    template = build_request_template(endpoint, include_optional=not args.required_only)
    if args.kind == "body":
        print(json.dumps(template.get("body", {}), indent=2))
        return
    if args.kind == "path":
        print(json.dumps(template.get("path_params", {}), indent=2))
        return
    if args.kind == "query":
        print(json.dumps(template.get("query", {}), indent=2))
        return
    if args.kind == "headers":
        print(json.dumps(template.get("headers", {}), indent=2))
        return
    print(json.dumps(template, indent=2))


def command_call(args):
    spec = load_spec()
    endpoint = find_endpoint(spec, args.selector)
    path_params = parse_pairs(args.path_param)
    query = parse_pairs(args.query)
    headers = parse_pairs(args.header)

    body_bytes = None
    if args.body_file:
        body_bytes = Path(args.body_file).read_bytes()
    elif args.body_json:
        body_bytes = args.body_json.encode("utf-8")

    if args.dry_run:
        rendered_path = render_path(endpoint["path"], path_params)
        mode = resolve_auth_mode()
        if mode == "access_token":
            auth_source = "direct_access_token"
        elif mode == "refresh_token" or can_refresh_access_token():
            auth_source = "refresh_token"
        else:
            auth_source = "direct_access_token"
        payload = {
            "method": endpoint.get("method"),
            "url": build_base_url() + (rendered_path if rendered_path.startswith("/") else "/" + rendered_path),
            "query": query,
            "headers": headers,
            "body_file": args.body_file,
            "body_json": maybe_parse_json(args.body_json) if args.body_json else None,
            "auth_source": auth_source,
        }
        print(json.dumps(payload, indent=2))
        return

    status, response_headers, body, url, request_headers = execute_request(
        endpoint,
        path_params,
        query,
        headers,
        body_bytes,
    )
    if args.output_file:
        Path(args.output_file).write_text(body, encoding="utf-8")

    if args.include_response_meta:
        payload = {
            "request": {
                "url": url,
                "method": endpoint.get("method"),
                "headers": request_headers,
            },
            "response": {
                "status": status,
                "headers": response_headers,
                "body": maybe_parse_json(body) if args.parse_json else body,
            },
        }
        print(json.dumps(payload, indent=2))
        return

    if args.parse_json:
        parsed = maybe_parse_json(body)
        if parsed is not None:
            print(json.dumps(parsed, indent=2))
            return
    print(body)


def summarize_connection_payload(selector, parsed_body):
    summary = {}
    if selector == "getorganization" and isinstance(parsed_body, dict):
        orgs = parsed_body.get("org")
        if isinstance(orgs, list) and orgs and isinstance(orgs[0], dict):
            org = orgs[0]
            for source_key, target_key in (
                ("company_name", "company_name"),
                ("id", "org_id"),
                ("type", "org_type"),
                ("primary_email", "primary_email"),
                ("zgid", "zgid"),
            ):
                value = org.get(source_key)
                if value:
                    summary[target_key] = value
    elif selector == "getavailableapis" and isinstance(parsed_body, dict):
        apis = parsed_body.get("__apis")
        if isinstance(apis, list):
            summary["available_api_count"] = len(apis)
    return summary


def run_connection_check(spec, selector):
    endpoint = find_endpoint(spec, selector)
    status, response_headers, body, url, _ = execute_request(endpoint, {}, {}, {}, None)
    parsed_body = maybe_parse_json(body)
    auth_context = resolve_auth_context()
    return {
        "selector": selector,
        "title": endpoint.get("title"),
        "status": status,
        "url": url,
        "auth_source": auth_context.get("source"),
        "response_headers": response_headers,
        "body": parsed_body if parsed_body is not None else body,
        "summary": summarize_connection_payload(selector, parsed_body),
    }


def command_check(args):
    spec = load_spec()
    selectors = [args.selector] if args.selector else list(DEFAULT_CONNECTION_CHECK_SELECTORS)
    attempts = []

    for selector in selectors:
        result = run_connection_check(spec, selector)
        attempts.append(result)
        if result["status"] == 200:
            if args.json:
                print(json.dumps({"ok": True, "attempts": attempts, "selected": selector}, indent=2))
                return

            print("PASS\tZoho connection verified")
            print(f"Check: {selector}")
            print(f"URL: {result['url']}")
            print(f"Auth: {result['auth_source']}")
            for key, value in result["summary"].items():
                print(f"{key}: {value}")
            return

        if not is_scope_or_permission_error(result["status"], json.dumps(result["body"]) if isinstance(result["body"], (dict, list)) else str(result["body"])):
            break

    if args.json:
        print(json.dumps({"ok": False, "attempts": attempts, "selected": attempts[-1]["selector"] if attempts else None}, indent=2))
        raise SystemExit(1)

    last_result = attempts[-1]
    print("FAIL\tZoho connection check failed")
    print(f"Check: {last_result['selector']}")
    print(f"Status: {last_result['status']}")
    print(f"URL: {last_result['url']}")
    print(f"Auth: {last_result['auth_source']}")
    if args.selector is None and is_scope_or_permission_error(
        last_result["status"],
        json.dumps(last_result["body"]) if isinstance(last_result["body"], (dict, list)) else str(last_result["body"]),
    ):
        print(
            "Reason: the built-in check endpoints may require scopes your token does not have. "
            "Try `zoho-cli check --selector <slug>` with an endpoint your token can read."
        )
    body = last_result["body"]
    if isinstance(body, (dict, list)):
        print(json.dumps(body, indent=2))
    else:
        print(body)
    raise SystemExit(1)


def resolve_path_value(data, path):
    current = data
    normalized = path.replace("[", ".").replace("]", "")
    for part in normalized.split("."):
        if part == "":
            continue
        if isinstance(current, list):
            current = current[int(part)]
        else:
            current = current[part]
    return current


def command_verify(args):
    manifest = json.loads(Path(args.manifest).read_text(encoding="utf-8"))
    checks = manifest.get("checks", [])
    if not isinstance(checks, list):
        raise SystemExit("Manifest must contain a top-level 'checks' array.")

    spec = load_spec()
    failures = []
    for check in checks:
        name = check.get("name") or check.get("selector")
        endpoint = find_endpoint(spec, check["selector"])
        status, _, body, _, _ = execute_request(
            endpoint,
            check.get("path_params", {}),
            check.get("query", {}),
            check.get("headers", {}),
            json.dumps(check["body"]).encode("utf-8") if "body" in check else None,
        )
        expected_status = check.get("expect_status", [200])
        if status not in expected_status:
            failures.append(f"{name}: expected status {expected_status}, got {status}")
            if args.fail_fast:
                break
            continue

        parsed = maybe_parse_json(body)
        if parsed is None and (check.get("expect_paths") or check.get("expect_values")):
            failures.append(f"{name}: response body is not valid JSON")
            if args.fail_fast:
                break
            continue

        for path in check.get("expect_paths", []):
            try:
                resolve_path_value(parsed, path)
            except Exception:
                failures.append(f"{name}: missing path {path}")
                if args.fail_fast:
                    break
        if failures and args.fail_fast:
            break

        for path, expected in check.get("expect_values", {}).items():
            try:
                actual = resolve_path_value(parsed, path)
            except Exception:
                failures.append(f"{name}: missing path {path}")
                if args.fail_fast:
                    break
                continue
            if actual != expected:
                failures.append(f"{name}: expected {path}={expected!r}, got {actual!r}")
                if args.fail_fast:
                    break
        if failures and args.fail_fast:
            break

        if args.verbose:
            print(f"PASS\t{name}")

    if failures:
        for failure in failures:
            print(f"FAIL\t{failure}")
        raise SystemExit(1)

    print(f"PASS\t{len(checks)} check(s)")


def build_parser():
    parser = argparse.ArgumentParser(description="Generic Zoho CRM CLI backed by a local API index.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    catalog = subparsers.add_parser("catalog", help="Inspect the generated endpoint catalog.")
    catalog_subparsers = catalog.add_subparsers(dest="catalog_command", required=True)
    list_command = catalog_subparsers.add_parser("list", help="List known endpoints.")
    list_command.add_argument("--method")
    list_command.add_argument("--section")
    list_command.add_argument("--group")
    list_command.add_argument("--module")
    list_command.add_argument("--scope")
    list_command.add_argument("--limit", type=int)
    list_command.add_argument("--json", action="store_true")
    show = catalog_subparsers.add_parser("show", help="Show one endpoint definition.")
    show.add_argument("selector")
    catalog.set_defaults(func=command_catalog)

    search = subparsers.add_parser("search", help="Search endpoints by free text and filters.")
    search.add_argument("query")
    search.add_argument("--method")
    search.add_argument("--section")
    search.add_argument("--group")
    search.add_argument("--module")
    search.add_argument("--scope")
    search.add_argument("--limit", type=int, default=25)
    search.add_argument("--json", action="store_true")
    search.set_defaults(func=command_search)

    template = subparsers.add_parser("template", help="Generate starter request templates.")
    template.add_argument("selector")
    template.add_argument("--kind", choices=["request", "body", "path", "query", "headers"], default="request")
    template.add_argument("--required-only", action="store_true")
    template.set_defaults(func=command_template)

    call = subparsers.add_parser("call", help="Execute any indexed endpoint.")
    call.add_argument("selector")
    call.add_argument("--path-param", action="append", default=[])
    call.add_argument("--query", action="append", default=[])
    call.add_argument("--header", action="append", default=[])
    call.add_argument("--body-file")
    call.add_argument("--body-json")
    call.add_argument("--dry-run", action="store_true")
    call.add_argument("--output-file")
    call.add_argument("--parse-json", action="store_true")
    call.add_argument("--include-response-meta", action="store_true")
    call.set_defaults(func=command_call)

    check = subparsers.add_parser("check", help="Verify live connectivity to the Zoho instance.")
    check.add_argument(
        "--selector",
        help="Optional endpoint slug to use for the connection check. Defaults to built-in read-only checks.",
    )
    check.add_argument("--json", action="store_true", help="Print structured output.")
    check.set_defaults(func=command_check)

    verify = subparsers.add_parser("verify", help="Run a verification manifest against live Zoho APIs.")
    verify.add_argument("manifest")
    verify.add_argument("--fail-fast", action="store_true")
    verify.add_argument("--verbose", action="store_true")
    verify.set_defaults(func=command_verify)

    return parser


def main():
    load_env_files()
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
